# ==========================
# Google Cloud
# ==========================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
VERTEX_AI_LOCATION=us-central1

# Gemini API (fallback if not using Vertex AI)
GEMINI_API_KEY=your-gemini-api-key

# ==========================
# Firebase / Firestore
# ==========================
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIRESTORE_DATABASE_ID=(default)

# ==========================
# Google Cloud Storage
# ==========================
GCS_BUCKET_NAME=community-hero-media

# ==========================
# Google Maps
# ==========================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ==========================
# ChromaDB
# ==========================
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ==========================
# Mem0
# ==========================
MEM0_API_KEY=your-mem0-api-key

# ==========================
# App Config
# ==========================
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:5173,https://your-firebase-app.web.app
MAX_RETRY_ATTEMPTS=3
CONFIDENCE_HIGH_THRESHOLD=0.80
CONFIDENCE_LOW_THRESHOLD=0.65
DUPLICATE_RADIUS_METERS=150
DUPLICATE_VISUAL_THRESHOLD=0.88
